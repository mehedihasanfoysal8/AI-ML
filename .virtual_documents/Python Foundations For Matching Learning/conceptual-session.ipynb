arr = [1, 2, 3, 4, 5, 6]

def fun1(x):
    return x * 10
    
# here use user define function
arr2 = list(map(fun1, arr))
print(arr2)


# here use lambda function
arr3 = list(map(lambda x : x * 10, arr))

print(arr3)


