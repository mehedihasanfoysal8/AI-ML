   "source": [
    "Given a list of integers, extract all numbers that are divisible by 3 but not divisibly by 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "e9e19673-9120-4e23-a695-b02d09963a3e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      " 3 5 9 10 15 18 20 21\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[3, 9, 18, 21]\n"
     ]
    }
   ],
   "source": [
    "numbers = input()\n",
    "number = numbers.split()\n",
    "\n",
    "result = []\n",
    "\n",
    "for i in number:\n",
    "    num = int(i)\n",
    "    if num % 3 == 0 and num % 5 != 0:\n",
    "       result.append(num)\n",
    "    \n",
    "print(result)\n"
   ]
  }
 ],
