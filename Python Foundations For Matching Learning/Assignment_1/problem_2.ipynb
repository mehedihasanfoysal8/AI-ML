    "def compute(a, b):\n",
    "    try:\n",
    "        result = ((a*a + b*b)) / ( a - b)\n",
    "        \n",
    "    except ZeroDivisionError:\n",
    "        print(\"Error : Division not possible\")\n",
    "        \n",
    "    else:\n",
    "        print(\"Computed result :\", result)\n",
    "        \n",
    "x, y = input().split()\n",
    "\n",
    "compute(int(x), int(y))"
   ]
  }
